# ═══════════════════════════════════════════════════════════
# Essential HICS — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to source control.
# ═══════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Database ───────────────────────────────────────────────
POSTGRES_USER=hics
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hics
DATABASE_URL=postgresql://hics:change_me_strong_password@localhost:5432/hics

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@localhost:6379

# ── JWT Secrets ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_ACCESS_EXPIRY=15m

JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET
JWT_REFRESH_EXPIRY=8h

# ── Encryption ─────────────────────────────────────────────
# AES-256 key for encrypting MFA secrets and SSO credentials at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_KEY

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourhospital.example
SMTP_PASSWORD=change_me_smtp_password
EMAIL_FROM="Essential HICS <noreply@yourhospital.example>"

# ── SSO — Azure AD ─────────────────────────────────────────
# Per-facility SSO config is stored in DB (health_systems.settings).
# These values are global fallback / used during initial setup.
AZURE_AD_TENANT_ID=your-azure-tenant-id
AZURE_AD_CLIENT_ID=your-azure-app-client-id
AZURE_AD_CLIENT_SECRET=your-azure-app-client-secret
AZURE_AD_REDIRECT_URI=http://localhost:3001/auth/sso/azure/callback

# ── SSO — Okta ─────────────────────────────────────────────
OKTA_DOMAIN=your-org.okta.com
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-client-secret
OKTA_REDIRECT_URI=http://localhost:3001/auth/sso/okta/callback

# ── SAML 2.0 (Azure AD enterprise app / Okta SAML) ─────────
# PEM-encoded SP private key and certificate (base64 or file path)
SAML_SP_PRIVATE_KEY=
SAML_SP_CERT=

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_REFRESH_WINDOW_MS=900000
RATE_LIMIT_RESET_MAX=5
RATE_LIMIT_RESET_WINDOW_MS=3600000

# ── MinIO (Object Storage for PDF exports) ─────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=hics_minio
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_ROOT_USER=hics_minio
MINIO_ROOT_PASSWORD=change_me_minio_secret
MINIO_BUCKET=hics-exports
# Signed URL expiry in seconds (default: 72 hours)
MINIO_SIGNED_URL_EXPIRY=259200

# ── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
