// FEMA Public Assistance damage categories
// CAT_A = Debris Removal, CAT_B = Emergency Protective Measures,
// CAT_C = Roads & Bridges, CAT_D = Water Control Facilities,
// CAT_E = Buildings & Equipment, CAT_F = Utilities,
// CAT_G = Parks & Recreation, CAT_Z = Management Costs (admin, ≤5%)
enum FemaPACategory {
  CAT_A
  CAT_B
  CAT_C
  CAT_D
  CAT_E
  CAT_F
  CAT_G
  CAT_Z
}

enum CostUnitPeriod {
  HOURLY
  DAILY
  WEEKLY
  FLAT
}

// ─── Core Org Models ─────────────────────────────────────────────────────────

model HealthSystem {
  id                    String     @id @default(uuid()) @db.Uuid
  name                  String
  shortName             String     @map("short_name")
  logoUrl               String?    @map("logo_url")
  primaryContactEmail   String     @map("primary_contact_email")
  // settings: MFA policy, session limits, SSO config per facility, etc.
  settings              Json       @default("{}")
  isDeleted             Boolean    @default(false) @map("is_deleted")
  deletedAt             DateTime?  @map("deleted_at") @db.Timestamptz
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  facilities            Facility[]
  users                 User[]

  @@map("health_systems")
}

model Facility {
  id                      String       @id @default(uuid()) @db.Uuid
  healthSystemId          String       @map("health_system_id") @db.Uuid
  name                    String
  shortName               String       @map("short_name")
  address                 Json         // { street, city, state, zip }
  phone                   String?
  fax                     String?
  licenseNumber           String?      @map("license_number")
  facilityType            FacilityType @default(HOSPITAL) @map("facility_type")
  isActive                Boolean      @default(true) @map("is_active")
  timezone                String       @default("America/New_York") // IANA tz
  emergencyContactName    String?      @map("emergency_contact_name")
  emergencyContactPhone   String?      @map("emergency_contact_phone")
  isDeleted               Boolean      @default(false) @map("is_deleted")
  deletedAt               DateTime?    @map("deleted_at") @db.Timestamptz
  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  healthSystem            HealthSystem       @relation(fields: [healthSystemId], references: [id])
  departments             Department[]
  userFacilityRoles       UserFacilityRole[]
  positions               Position[]
  auditLogs               AuditLog[]

  @@index([healthSystemId])
  @@map("facilities")
}

model Department {
  id                 String      @id @default(uuid()) @db.Uuid
  facilityId         String      @map("facility_id") @db.Uuid
  name               String
  code               String
  parentDepartmentId String?     @map("parent_department_id") @db.Uuid
  isActive           Boolean     @default(true) @map("is_active")
  isDeleted          Boolean     @default(false) @map("is_deleted")
  deletedAt          DateTime?   @map("deleted_at") @db.Timestamptz
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  facility           Facility    @relation(fields: [facilityId], references: [id])
  parentDepartment   Department? @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")
  positions          Position[]

  @@index([facilityId])
  @@map("departments")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                  String       @id @default(uuid()) @db.Uuid
  healthSystemId      String       @map("health_system_id") @db.Uuid
  email               String       @unique
  firstName           String       @map("first_name")
  lastName            String       @map("last_name")
  displayName         String?      @map("display_name")
  jobTitle            String?      @map("job_title")
  employeeId          String?      @map("employee_id")
  phoneMobile         String?      @map("phone_mobile")
  phoneWork           String?      @map("phone_work")
  pagerNumber         String?      @map("pager_number")
  passwordHash        String?      @map("password_hash")
  authProvider        AuthProvider @default(LOCAL) @map("auth_provider")
  externalId          String?      @map("external_id") // SSO subject id
  isActive            Boolean      @default(true) @map("is_active")
  isLocked            Boolean      @default(false) @map("is_locked")
  lockedUntil         DateTime?    @map("locked_until") @db.Timestamptz
  failedLoginAttempts Int          @default(0) @map("failed_login_attempts")
  lastLoginAt         DateTime?    @map("last_login_at") @db.Timestamptz
  passwordChangedAt   DateTime?    @map("password_changed_at") @db.Timestamptz
  mustChangePassword  Boolean      @default(true) @map("must_change_password")
  // Stored encrypted (AES-256) at application level
  mfaEnabled          Boolean      @default(false) @map("mfa_enabled")
  mfaSecret           String?      @map("mfa_secret") // AES-256 encrypted
  mfaBackupCodes      String[]     @map("mfa_backup_codes") // AES-256 encrypted array
  createdBy           String?      @map("created_by") @db.Uuid
  isDeleted           Boolean      @default(false) @map("is_deleted")
  deletedAt           DateTime?    @map("deleted_at") @db.Timestamptz
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  healthSystem        HealthSystem      @relation(fields: [healthSystemId], references: [id])
  createdByUser       User?             @relation("UserCreatedBy", fields: [createdBy], references: [id])
  createdUsers        User[]            @relation("UserCreatedBy")
  userFacilityRoles   UserFacilityRole[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  auditLogsActed      AuditLog[]        @relation("AuditActorUser")

  @@index([email])
  @@index([healthSystemId])
  @@map("users")
}

model UserFacilityRole {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  facilityId        String    @map("facility_id") @db.Uuid
  hicsRole          HicsRole  @map("hics_role")
  isPrimaryFacility Boolean   @default(false) @map("is_primary_facility")
  assignedBy        String?   @map("assigned_by") @db.Uuid
  assignedAt        DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  isDeleted         Boolean   @default(false) @map("is_deleted")
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user              User      @relation(fields: [userId], references: [id])
  facility          Facility  @relation(fields: [facilityId], references: [id])

  @@unique([userId, facilityId, hicsRole])
  @@index([userId])
  @@index([facilityId])
  @@map("user_facility_roles")
}

// HICS position directory — who is slotted into which role at a facility
model Position {
  id               String    @id @default(uuid()) @db.Uuid
  facilityId       String    @map("facility_id") @db.Uuid
  hicsRole         HicsRole  @map("hics_role")
  displayName      String    @map("display_name")
  reportsToRole    HicsRole? @map("reports_to_role")
  departmentId     String?   @map("department_id") @db.Uuid
  contactOverride  Json?     @map("contact_override")
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  facility         Facility   @relation(fields: [facilityId], references: [id])
  department       Department? @relation(fields: [departmentId], references: [id])

  @@index([facilityId])
  @@map("positions")
}

// ─── Sessions & Auth Tokens ───────────────────────────────────────────────────

model Session {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  refreshToken   String    @unique @map("refresh_token") // hashed
  deviceInfo     String?   @map("device_info")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent")
  lastUsedAt     DateTime  @default(now()) @map("last_used_at") @db.Timestamptz
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  isRevoked      Boolean   @default(false) @map("is_revoked")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") // SHA-256 of raw token
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  usedAt     DateTime? @map("used_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  timestamp      DateTime     @default(now()) @db.Timestamptz
  actorUserId    String?      @map("actor_user_id") @db.Uuid
  actorIpAddress String?      @map("actor_ip_address")
  actorUserAgent String?      @map("actor_user_agent")
  facilityId     String?      @map("facility_id") @db.Uuid
  incidentId     String?      @map("incident_id") @db.Uuid // reserved for Phase 2
  action         AuditAction
  resourceType   String       @map("resource_type")
  resourceId     String       @map("resource_id")
  changes        Json?        // { before: {...}, after: {...} }
  metadata       Json?

  actorUser      User?        @relation("AuditActorUser", fields: [actorUserId], references: [id])
  facility       Facility?    @relation(fields: [facilityId], references: [id])
  incident       Incident?    @relation(fields: [incidentId], references: [id])

  @@index([timestamp])
  @@index([actorUserId])
  @@index([facilityId])
  @@index([incidentId])
  @@index([action])
  @@index([resourceType])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════
// PHASE 2 — INCIDENTS, IAP, TEMPLATES, ORG BOARD, NOTIFICATIONS
// ═══════════════════════════════════════════════════════════

// ─── Incidents ───────────────────────────────────────────────────────────────

model Incident {
  id                   String           @id @default(uuid()) @db.Uuid
  facilityId           String           @map("facility_id") @db.Uuid
  healthSystemId       String           @map("health_system_id") @db.Uuid
  incidentNumber       String           @map("incident_number")
  name                 String
  incidentType         IncidentType     @map("incident_type")
  status               IncidentStatus   @default(PLANNING)
  severity             IncidentSeverity
  declarationTime      DateTime         @map("declaration_time") @db.Timestamptz
  estimatedEndTime     DateTime?        @map("estimated_end_time") @db.Timestamptz
  actualEndTime        DateTime?        @map("actual_end_time") @db.Timestamptz
  incidentLocation     String?          @map("incident_location")
  situationSummary     String?          @map("situation_summary")
  isExercise           Boolean          @default(false) @map("is_exercise")
  createdBy            String           @map("created_by") @db.Uuid
  incidentCommanderId  String?          @map("incident_commander_id") @db.Uuid
  closedAt             DateTime?        @map("closed_at") @db.Timestamptz
  isDeleted            Boolean          @default(false) @map("is_deleted")
  deletedAt            DateTime?        @map("deleted_at") @db.Timestamptz
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  facility              Facility                     @relation(fields: [facilityId], references: [id])
  createdByUser         User                         @relation("IncidentCreatedBy", fields: [createdBy], references: [id])
  incidentCommander     User?                        @relation("IncidentCommander", fields: [incidentCommanderId], references: [id])
  operationalPeriods    OperationalPeriod[]
  positionAssignments   IncidentPositionAssignment[]
  messages              IapForm213[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  // Phase 3
  incidentResources     IncidentResource[]
  resourceRequests      ResourceRequest[]
  costRecords           CostRecord[]
  costRollups           CostRollup[]
  exportJobs            ExportJob[]

  @@unique([facilityId, incidentNumber])
  @@index([facilityId, status])
  @@index([healthSystemId])
  @@map("incidents")
}

model OperationalPeriod {
  id              String                  @id @default(uuid()) @db.Uuid
  incidentId      String                  @map("incident_id") @db.Uuid
  periodNumber    Int                     @map("period_number")
  startTime       DateTime                @map("start_time") @db.Timestamptz
  endTime         DateTime                @map("end_time") @db.Timestamptz
  status          OperationalPeriodStatus @default(DRAFT)
  weatherForecast String?                 @map("weather_forecast")
  createdBy       String                  @map("created_by") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  incident        Incident           @relation(fields: [incidentId], references: [id])
  createdByUser   User               @relation("OpPeriodCreatedBy", fields: [createdBy], references: [id])
  iap             Iap?
  form201         IapForm201?
  form202         IapForm202?
  form203         IapForm203?
  form204s        IapForm204[]
  form207         IapForm207?
  form215         IapForm215?
  form215a        IapForm215a?
  hics251         IapFormHics251?
  hics252         IapFormHics252?
  positionAssignments IncidentPositionAssignment[]
  // Phase 3
  costRecords     CostRecord[]
  costRollup      CostRollup?
  resourceAssignments ResourceAssignment[]

  @@unique([incidentId, periodNumber])
  @@index([incidentId, status])
  @@map("operational_periods")
}

// ─── IAP Master ───────────────────────────────────────────────────────────────

model Iap {
  id                      String    @id @default(uuid()) @db.Uuid
  operationalPeriodId     String    @unique @map("operational_period_id") @db.Uuid
  incidentId              String    @map("incident_id") @db.Uuid
  status                  IapStatus @default(DRAFT)
  versionNumber           Int       @default(1) @map("version_number")
  templateId              String?   @map("template_id") @db.Uuid
  createdBy               String    @map("created_by") @db.Uuid
  submittedForReviewAt    DateTime? @map("submitted_for_review_at") @db.Timestamptz
  submittedByUserId       String?   @map("submitted_by_user_id") @db.Uuid
  reviewedAt              DateTime? @map("reviewed_at") @db.Timestamptz
  reviewedByUserId        String?   @map("reviewed_by_user_id") @db.Uuid
  approvedAt              DateTime? @map("approved_at") @db.Timestamptz
  approvedByUserId        String?   @map("approved_by_user_id") @db.Uuid
  publishedAt             DateTime? @map("published_at") @db.Timestamptz
  publishedByUserId       String?   @map("published_by_user_id") @db.Uuid
  approvalNotes           String?   @map("approval_notes")
  exportedPdfUrl          String?   @map("exported_pdf_url")
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  operationalPeriod       OperationalPeriod    @relation(fields: [operationalPeriodId], references: [id])
  createdByUser           User                 @relation("IapCreatedBy", fields: [createdBy], references: [id])
  template                IapTemplate?         @relation(fields: [templateId], references: [id])
  reviewAssignments       IapReviewAssignment[]
  comments                IapComment[]
  exportJobs              ExportJob[]

  @@index([incidentId, status])
  @@map("iaps")
}

model IapReviewAssignment {
  id                 String    @id @default(uuid()) @db.Uuid
  iapId              String    @map("iap_id") @db.Uuid
  assignedToUserId   String    @map("assigned_to_user_id") @db.Uuid
  assignedByUserId   String    @map("assigned_by_user_id") @db.Uuid
  assignedAt         DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  completedAt        DateTime? @map("completed_at") @db.Timestamptz
  notes              String?
  action             String    @default("PENDING") // APPROVED | RETURNED | PENDING

  iap                Iap       @relation(fields: [iapId], references: [id])
  assignedToUser     User      @relation("ReviewAssignedTo", fields: [assignedToUserId], references: [id])
  assignedByUser     User      @relation("ReviewAssignedBy", fields: [assignedByUserId], references: [id])

  @@map("iap_review_assignments")
}

model IapComment {
  id                  String    @id @default(uuid()) @db.Uuid
  iapId               String    @map("iap_id") @db.Uuid
  formReference       String    @map("form_reference")
  fieldReference      String?   @map("field_reference")
  commentText         String    @map("comment_text")
  authorUserId        String    @map("author_user_id") @db.Uuid
  isResolved          Boolean   @default(false) @map("is_resolved")
  resolvedByUserId    String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt          DateTime? @map("resolved_at") @db.Timestamptz
  parentCommentId     String?   @map("parent_comment_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

