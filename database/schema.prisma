// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3 — RESOURCE TRACKING, 213RR, COST LEDGER, FEMA PA EXPORT
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Resource Catalog ─────────────────────────────────────────────────────────

// Master list of resource types (NIMS-typed, scoped to health system or facility)
model ResourceType {
  id                   String           @id @default(uuid()) @db.Uuid
  facilityId           String?          @map("facility_id") @db.Uuid       // null = health-system-wide
  healthSystemId       String           @map("health_system_id") @db.Uuid
  nimsKind             NimsKind         @map("nims_kind")
  name                 String
  description          String?
  unit                 String                                               // each, box, pallet, hours, etc.
  category             ResourceCategory
  defaultCostPerUnit   Decimal?         @map("default_cost_per_unit") @db.Decimal(12, 4)
  defaultCostUnitPeriod CostUnitPeriod? @map("default_cost_unit_period")
  isActive             Boolean          @default(true) @map("is_active")
  isDeleted            Boolean          @default(false) @map("is_deleted")
  deletedAt            DateTime?        @map("deleted_at") @db.Timestamptz
  createdBy            String           @map("created_by") @db.Uuid
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  facility             Facility?        @relation(fields: [facilityId], references: [id])
  inventory            FacilityResourceInventory[]
  incidentResources    IncidentResource[]
  requestLineItems     ResourceRequestLineItem[]

  @@index([healthSystemId, nimsKind])
  @@index([facilityId])
  @@map("resource_types")
}

// Facility's pre-incident inventory snapshot of each resource type
model FacilityResourceInventory {
  id                String       @id @default(uuid()) @db.Uuid
  facilityId        String       @map("facility_id") @db.Uuid
  resourceTypeId    String       @map("resource_type_id") @db.Uuid
  quantityOnHand    Decimal      @default(0) @map("quantity_on_hand") @db.Decimal(10, 2)
  quantityAvailable Decimal      @default(0) @map("quantity_available") @db.Decimal(10, 2)
  storageLocation   String?      @map("storage_location")
  notes             String?
  lastUpdatedBy     String?      @map("last_updated_by") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  facility          Facility     @relation(fields: [facilityId], references: [id])
  resourceType      ResourceType @relation(fields: [resourceTypeId], references: [id])

  @@unique([facilityId, resourceTypeId])
  @@index([facilityId])
  @@map("facility_resource_inventory")
}

// ─── Incident Resources ───────────────────────────────────────────────────────

// A resource record created when a resource is ordered / deployed for an incident.
// Tracks the full ICS resource lifecycle.
model IncidentResource {
  id                    String           @id @default(uuid()) @db.Uuid
  incidentId            String           @map("incident_id") @db.Uuid
  facilityId            String           @map("facility_id") @db.Uuid
  resourceTypeId        String?          @map("resource_type_id") @db.Uuid  // null = ad-hoc (no catalog entry)
  name                  String                                               // display name / description
  nimsKind              NimsKind         @map("nims_kind")
  quantity              Decimal          @default(1) @db.Decimal(10, 2)
  unit                  String           @default("each")
  source                ResourceSource   @default(INTERNAL)
  status                ResourceStatus   @default(ORDERED)
  resourceIdentifier    String?          @map("resource_identifier")        // license plate, asset tag, etc.
  homeBaseOrgName       String?          @map("home_base_org_name")
  homeBaseContact       String?          @map("home_base_contact")
  requestId             String?          @map("request_id") @db.Uuid        // FK to ResourceRequest
  eta                   DateTime?        @map("eta") @db.Timestamptz
  assignedToRole        HicsRole?        @map("assigned_to_role")
  assignedToLocation    String?          @map("assigned_to_location")
  costPerUnit           Decimal?         @map("cost_per_unit") @db.Decimal(12, 4)
  costUnitPeriod        CostUnitPeriod?  @map("cost_unit_period")
  // Lifecycle timestamps — set when status transitions occur
  orderedAt             DateTime?        @map("ordered_at") @db.Timestamptz
  inTransitAt           DateTime?        @map("in_transit_at") @db.Timestamptz
  assignedAt            DateTime?        @map("assigned_at") @db.Timestamptz
  availableAt           DateTime?        @map("available_at") @db.Timestamptz
  outOfServiceAt        DateTime?        @map("out_of_service_at") @db.Timestamptz
  demobilizedAt         DateTime?        @map("demobilized_at") @db.Timestamptz
  notes                 String?
  createdBy             String           @map("created_by") @db.Uuid
  isDeleted             Boolean          @default(false) @map("is_deleted")
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  incident              Incident         @relation(fields: [incidentId], references: [id])
  facility              Facility         @relation(fields: [facilityId], references: [id])
  resourceType          ResourceType?    @relation(fields: [resourceTypeId], references: [id])
  request               ResourceRequest? @relation(fields: [requestId], references: [id])
  statusHistory         ResourceStatusHistory[]
  assignments           ResourceAssignment[]
  fulfillments          RequestFulfillment[]
  equipmentCostRecords  EquipmentCostRecord[]

  @@index([incidentId, status])
  @@index([incidentId, nimsKind])
  @@index([facilityId])
  @@map("incident_resources")
}

// Append-only resource status change history.
// Trigger: prevent_resource_status_history_mutation() (mirrors audit_logs pattern)
model ResourceStatusHistory {
  id                 String         @id @default(uuid()) @db.Uuid
  incidentResourceId String         @map("incident_resource_id") @db.Uuid
  fromStatus         ResourceStatus? @map("from_status")
  toStatus           ResourceStatus @map("to_status")
  changedByUserId    String?        @map("changed_by_user_id") @db.Uuid
  changedAt          DateTime       @default(now()) @map("changed_at") @db.Timestamptz
  location           String?
  notes              String?

  incidentResource   IncidentResource @relation(fields: [incidentResourceId], references: [id])

  @@index([incidentResourceId, changedAt])
  @@map("resource_status_history")
}

// Active assignment of an incident resource to a specific role / location / period
model ResourceAssignment {
  id                    String             @id @default(uuid()) @db.Uuid
  incidentResourceId    String             @map("incident_resource_id") @db.Uuid
  incidentId            String             @map("incident_id") @db.Uuid
  operationalPeriodId   String?            @map("operational_period_id") @db.Uuid
  assignedToRole        HicsRole?          @map("assigned_to_role")
  assignedToLocation    String?            @map("assigned_to_location")
  assignedByUserId      String             @map("assigned_by_user_id") @db.Uuid
  assignedAt            DateTime           @default(now()) @map("assigned_at") @db.Timestamptz
  releasedAt            DateTime?          @map("released_at") @db.Timestamptz
  taskDescription       String?            @map("task_description")
  notes                 String?
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  incidentResource      IncidentResource   @relation(fields: [incidentResourceId], references: [id])
  incident              Incident           @relation(fields: [incidentId], references: [id])
  operationalPeriod     OperationalPeriod? @relation(fields: [operationalPeriodId], references: [id])

  @@index([incidentId, operationalPeriodId])
  @@index([incidentResourceId])
  @@map("resource_assignments")
}

// ─── ICS-213RR Resource Request Workflow ─────────────────────────────────────

// ICS Form 213RR — Resource Request.
// Auto-numbered: 213RR-{incidentNumber}-{####}
model ResourceRequest {
  id                    String          @id @default(uuid()) @db.Uuid
  requestNumber         String          @map("request_number")              // e.g. 213RR-APGE-2026-0001-0001
  incidentId            String          @map("incident_id") @db.Uuid
  facilityId            String          @map("facility_id") @db.Uuid
  requestedByUserId     String          @map("requested_by_user_id") @db.Uuid
  priority              RequestPriority @default(ROUTINE)
  status                RequestStatus   @default(DRAFT)
  missionAssignment     String?         @map("mission_assignment")
  requestedForRole      HicsRole?       @map("requested_for_role")
  requestedForSection   String?         @map("requested_for_section")
  deliveryLocation      String?         @map("delivery_location")
  deliveryBy            DateTime?       @map("delivery_by") @db.Timestamptz
  neededDate            DateTime?       @map("needed_date") @db.Timestamptz
  estimatedCost         Decimal?        @map("estimated_cost") @db.Decimal(12, 4)
  justification         String?
  // Workflow timestamps
  submittedAt           DateTime?       @map("submitted_at") @db.Timestamptz
  submittedByUserId     String?         @map("submitted_by_user_id") @db.Uuid
  approvedAt            DateTime?       @map("approved_at") @db.Timestamptz
  approvedByUserId      String?         @map("approved_by_user_id") @db.Uuid
  approvalNotes         String?         @map("approval_notes")
  deniedAt              DateTime?       @map("denied_at") @db.Timestamptz
  deniedByUserId        String?         @map("denied_by_user_id") @db.Uuid
  denialReason          String?         @map("denial_reason")
  cancelledAt           DateTime?       @map("cancelled_at") @db.Timestamptz
  cancelledByUserId     String?         @map("cancelled_by_user_id") @db.Uuid
  isDeleted             Boolean         @default(false) @map("is_deleted")
  deletedAt             DateTime?       @map("deleted_at") @db.Timestamptz
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  incident              Incident        @relation(fields: [incidentId], references: [id])
  facility              Facility        @relation(fields: [facilityId], references: [id])
  requestedByUser       User            @relation("RequestedByUser", fields: [requestedByUserId], references: [id])
  lineItems             ResourceRequestLineItem[]
  incidentResources     IncidentResource[]

  @@unique([incidentId, requestNumber])
  @@index([incidentId, status])
  @@index([facilityId])
  @@map("resource_requests")
}

// Line item within a 213RR request
model ResourceRequestLineItem {
  id                   String       @id @default(uuid()) @db.Uuid
  requestId            String       @map("request_id") @db.Uuid
  resourceTypeId       String?      @map("resource_type_id") @db.Uuid
  resourceDescription  String       @map("resource_description")           // free-text if no catalog type
  quantity             Decimal      @db.Decimal(10, 2)
  unit                 String       @default("each")
  estimatedUnitCost    Decimal?     @map("estimated_unit_cost") @db.Decimal(12, 4)
  estimatedTotalCost   Decimal?     @map("estimated_total_cost") @db.Decimal(12, 4)
  filledQuantity       Decimal      @default(0) @map("filled_quantity") @db.Decimal(10, 2)
  notes                String?
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  request              ResourceRequest @relation(fields: [requestId], references: [id])
  resourceType         ResourceType?   @relation(fields: [resourceTypeId], references: [id])
  fulfillments         RequestFulfillment[]

  @@index([requestId])
  @@map("resource_request_line_items")
}

// Records how each line item was fulfilled by actual incident resources
model RequestFulfillment {
  id                String            @id @default(uuid()) @db.Uuid
  lineItemId        String            @map("line_item_id") @db.Uuid
  incidentResourceId String           @map("incident_resource_id") @db.Uuid
  quantityFulfilled Decimal           @map("quantity_fulfilled") @db.Decimal(10, 2)
  fulfilledByUserId String            @map("fulfilled_by_user_id") @db.Uuid
  fulfilledAt       DateTime          @default(now()) @map("fulfilled_at") @db.Timestamptz
  notes             String?
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz

  lineItem          ResourceRequestLineItem @relation(fields: [lineItemId], references: [id])
  incidentResource  IncidentResource        @relation(fields: [incidentResourceId], references: [id])

  @@index([lineItemId])
  @@map("request_fulfillments")
}

// ─── Mutual Aid ───────────────────────────────────────────────────────────────

// Pre-negotiated mutual aid agreement with an external organization
model MutualAidAgreement {
  id                       String     @id @default(uuid()) @db.Uuid
  facilityId               String     @map("facility_id") @db.Uuid
  healthSystemId           String     @map("health_system_id") @db.Uuid
  partnerOrganizationName  String     @map("partner_organization_name")
  partnerContactName       String?    @map("partner_contact_name")
  partnerContactPhone      String?    @map("partner_contact_phone")
  partnerContactEmail      String?    @map("partner_contact_email")
  agreementType            String     @map("agreement_type")               // e.g. EMAC, NIMS, bilateral MOU
  agreementNumber          String?    @map("agreement_number")
  effectiveDate            DateTime?  @map("effective_date") @db.Date
  expirationDate           DateTime?  @map("expiration_date") @db.Date
  resourceCategories       String[]   @map("resource_categories")          // NimsKind values covered
  terms                    String?
  isActive                 Boolean    @default(true) @map("is_active")
  createdBy                String     @map("created_by") @db.Uuid
  createdAt                DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  facility                 Facility   @relation(fields: [facilityId], references: [id])

  @@index([facilityId])
  @@index([healthSystemId])
  @@map("mutual_aid_agreements")
}

// ─── Cost Ledger ──────────────────────────────────────────────────────────────

// General cost record — one entry per distinct cost event / invoice line
model CostRecord {
  id                  String           @id @default(uuid()) @db.Uuid
  incidentId          String           @map("incident_id") @db.Uuid
  operationalPeriodId String?          @map("operational_period_id") @db.Uuid
  costType            CostType         @map("cost_type")
  femaPACategory      FemaPACategory   @map("fema_pa_category")
  description         String
  quantity            Decimal          @default(1) @db.Decimal(10, 3)
  unitCost            Decimal          @map("unit_cost") @db.Decimal(12, 4)
  totalCost           Decimal          @map("total_cost") @db.Decimal(14, 4) // computed: qty × unitCost
  vendor              String?
  invoiceNumber       String?          @map("invoice_number")
  documentationUrl    String?          @map("documentation_url")
  incurredAt          DateTime         @map("incurred_at") @db.Timestamptz
  recordedByUserId    String           @map("recorded_by_user_id") @db.Uuid
  isApproved          Boolean          @default(false) @map("is_approved")
  approvedByUserId    String?          @map("approved_by_user_id") @db.Uuid
  approvedAt          DateTime?        @map("approved_at") @db.Timestamptz
  notes               String?
  isDeleted           Boolean          @default(false) @map("is_deleted")
  deletedAt           DateTime?        @map("deleted_at") @db.Timestamptz
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  incident            Incident         @relation(fields: [incidentId], references: [id])
  operationalPeriod   OperationalPeriod? @relation(fields: [operationalPeriodId], references: [id])
  recordedByUser      User             @relation("CostRecordedBy", fields: [recordedByUserId], references: [id])
  laborCostRecord     LaborCostRecord?
  equipmentCostRecord EquipmentCostRecord?

  @@index([incidentId, costType])
  @@index([incidentId, femaPACategory])
  @@index([incidentId, operationalPeriodId])
  @@map("cost_records")
}

// Labor detail — linked 1:1 to a CostRecord with costType = LABOR
model LaborCostRecord {
  id              String      @id @default(uuid()) @db.Uuid
  costRecordId    String      @unique @map("cost_record_id") @db.Uuid
  userId          String?     @map("user_id") @db.Uuid                // null = external / contracted labor
  employeeId      String?     @map("employee_id")
  position        String?                                              // job title / HICS role
  regularHours    Decimal     @default(0) @map("regular_hours") @db.Decimal(8, 2)
  overtimeHours   Decimal     @default(0) @map("overtime_hours") @db.Decimal(8, 2)
  regularRate     Decimal     @default(0) @map("regular_rate") @db.Decimal(10, 4)  // $/hr
  overtimeRate    Decimal     @default(0) @map("overtime_rate") @db.Decimal(10, 4) // $/hr (usually 1.5×)
  benefits        Decimal     @default(0) @db.Decimal(10, 4)          // fringe benefits added on top
  totalLaborCost  Decimal     @map("total_labor_cost") @db.Decimal(14, 4)
  periodStart     DateTime?   @map("period_start") @db.Timestamptz
  periodEnd       DateTime?   @map("period_end") @db.Timestamptz
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  costRecord      CostRecord  @relation(fields: [costRecordId], references: [id])
  user            User?       @relation("LaborCostUser", fields: [userId], references: [id])

  @@index([costRecordId])
  @@map("labor_cost_records")
}

// Equipment detail — linked 1:1 to a CostRecord with costType = EQUIPMENT
model EquipmentCostRecord {
  id                    String            @id @default(uuid()) @db.Uuid
  costRecordId          String            @unique @map("cost_record_id") @db.Uuid
  incidentResourceId    String?           @map("incident_resource_id") @db.Uuid // FK to deployed resource
  equipmentType         String            @map("equipment_type")
  equipmentIdentifier   String?           @map("equipment_identifier")          // asset tag / license plate
  hours                 Decimal           @default(0) @db.Decimal(8, 2)
  dailyRate             Decimal           @default(0) @map("daily_rate") @db.Decimal(10, 4)
  mileage               Decimal           @default(0) @db.Decimal(10, 2)
  mileageRate           Decimal           @default(0) @map("mileage_rate") @db.Decimal(8, 4) // $/mile
  totalEquipmentCost    Decimal           @map("total_equipment_cost") @db.Decimal(14, 4)
  operator              String?
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  costRecord            CostRecord        @relation(fields: [costRecordId], references: [id])
  incidentResource      IncidentResource? @relation(fields: [incidentResourceId], references: [id])

  @@index([costRecordId])
  @@map("equipment_cost_records")
}

// ─── Cost Rollups ─────────────────────────────────────────────────────────────

// Pre-computed cost snapshot (refreshed every 15 min by cron + on-demand).
// NEVER aggregate cost_records at query time — always read from this table.
model CostRollup {
  id                   String             @id @default(uuid()) @db.Uuid
  incidentId           String             @map("incident_id") @db.Uuid
  operationalPeriodId  String?            @unique @map("operational_period_id") @db.Uuid // null = incident total
  computedAt           DateTime           @default(now()) @map("computed_at") @db.Timestamptz
  totalCost            Decimal            @map("total_cost") @db.Decimal(16, 4)
  laborCost            Decimal            @map("labor_cost") @db.Decimal(14, 4)
  equipmentCost        Decimal            @map("equipment_cost") @db.Decimal(14, 4)
  supplyCost           Decimal            @map("supply_cost") @db.Decimal(14, 4)
  contractCost         Decimal            @map("contract_cost") @db.Decimal(14, 4)
  overheadCost         Decimal            @map("overhead_cost") @db.Decimal(14, 4)
  // FEMA PA breakdown — { "CAT_A": 1000.00, "CAT_B": 5000.00, ... }
  costByFemaCategory   Json               @map("cost_by_fema_category")
  // Period-by-period breakdown for trend charts — [{ periodNumber, totalCost }, ...]
  costByPeriod         Json               @map("cost_by_period")
  laborHours           Decimal            @default(0) @map("labor_hours") @db.Decimal(12, 2)
  equipmentHours       Decimal            @default(0) @map("equipment_hours") @db.Decimal(12, 2)
  headcount            Int                @default(0)
  approvedCost         Decimal            @map("approved_cost") @db.Decimal(16, 4)
  unapprovedCost       Decimal            @map("unapproved_cost") @db.Decimal(16, 4)
  recordCount          Int                @default(0) @map("record_count")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz

  incident             Incident           @relation(fields: [incidentId], references: [id])
  operationalPeriod    OperationalPeriod? @relation(fields: [operationalPeriodId], references: [id])

  @@index([incidentId, computedAt])
  @@map("cost_rollups")
}
