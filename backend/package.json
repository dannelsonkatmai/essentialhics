{
  "name": "hics-backend",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "ts-node-dev --respawn --transpile-only src/jobs/pdfExport.worker.ts",
    "worker:fema": "ts-node-dev --respawn --transpile-only src/jobs/femaExport.worker.ts",
    "worker:cost-pdf": "ts-node-dev --respawn --transpile-only src/jobs/periodCostPdf.worker.ts",
    "cron": "ts-node-dev --respawn --transpile-only src/jobs/scheduler.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint src --ext .ts",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "fast-json-patch": "^3.1.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.5",
    "passport-oauth2": "^1.8.0",
    "passport-saml": "^3.2.4",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^22.12.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.7.5",
    "winston": "^3.13.0",
    "zod": "^3.23.8",
    "decimal.js": "^10.4.3",
    "exceljs": "^4.4.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bull": "^4.10.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/passport": "^1.0.16",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "@types/node-cron": "^3.0.11"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.ts", "**/*.test.ts", "**/*.spec.ts"],
    "collectCoverageFrom": ["src/**/*.ts", "!src/server.ts"],
    "coverageThreshold": {
      "global": { "lines": 80 }
    }
  }
}
